extends layout

block title
  | #{product.name}

block content
  h1= product.name

  .product-card(style="max-width:600px;margin:2rem auto;")
    p
      strong Category:
      |  #{product.category}

    p
      strong Type:
      |  #{product.type}

    p
      strong Course Level:
      |  #{product.courseLevel}

    p
      strong Format:
      |  #{product.format}

    p
      strong Professor Style:
      |  #{product.professorStyle}

    p
      strong Price:
      |  $#{product.price.toFixed(2)}

    div(style="display:flex;gap:1rem;margin-top:1.5rem;align-items:center;")
      a.view-details(href="/products") ← Back to Products

      form(action="/cart/add", method="POST", style="margin:0;display:flex;")
        input(type="hidden", name="name", value=product.name)
        input(type="hidden", name="price", value=product.price)
        button.add-to-cart(type="submit", style="line-height:1.5;display:block;") 🛒 Add to Cart