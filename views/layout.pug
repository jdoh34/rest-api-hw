doctype html
html
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title
      block title
        | Gator Assignment Aid
    link(rel="stylesheet", href="/styles.css")
  body
    nav
      .nav-container
        a.logo-container(href="/")
          img.logo(src="/images/logo.png", alt="Gator Assignment Aid Logo")
          span.logo-text Gator Assignment Aid - "Less stress. More A's."
        .nav-links
          a(href="/") Home
          a(href="/products") Products
          a(href="/cart") Cart

          if user
            a(href="/profile") Hi, #{user.name}
            form(action="/logout", method="POST", style="display:inline;")
              button(type="submit", style="background:none;border:none;color:#475569;font-weight:500;cursor:pointer;font-family:inherit;font-size:1rem;") Logout
          else
            a(href="/login") Login
            a.signup-btn(href="/signup") ✨ Sign Up ✨

    .discount-banner
      span 🎓 STUDENT DEAL 🎓
      |  Get 20% OFF your first order! 
      a(href="/signup") Claim Now →

    .container
      block content

    footer
      p © 2026 Gator Assignment Aid
      p Team: Grisma Dhakal | Joonsung Oh | Davis Oduor | Aarzu Karki
