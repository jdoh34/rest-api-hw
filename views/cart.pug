extends layout

block title
  | Shopping Cart

block content
  h1 Shopping Cart
  
  if cartItems && cartItems.length
    if user
      .discount-code
        span 🎉 WELCOME DISCOUNT 🎉
        .code GATOR-#{Math.floor(Math.random() * 90000) + 10000}
        p Use this code at checkout for 20% OFF your first order!
    
    table.cart-table
      thead
        tr
          th Item
          th Price
          th Quantity
          th Subtotal
          th
      tbody
        each item in cartItems
          tr
            td= item.name
            td $#{item.price.toFixed(2)}
            td= item.quantity
            td $#{(item.price * item.quantity).toFixed(2)}
            td
              form(action="/cart/remove", method="POST")
                input(type="hidden", name="name", value=item.name)
                button.remove-btn(type="submit") Remove
    
    .cart-total
      strong Total: $#{total}
    
    .cart-buttons
      a.btn-secondary(href="/products") ← Keep Shopping
      a.btn-primary(href="/checkout") Proceed to Checkout →
  else
    .empty-cart
      p Your cart is empty.
      a.btn-primary(href="/products") Browse Services →
