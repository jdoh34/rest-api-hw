extends layout

block title
  | Forgot Password

block content
  .form-card
    h2 Forgot Password?
    p Enter your email address to recover your password.
    
    form(action="/forgot-password", method="POST")
      .form-group
        label(for="email") Email Address
        input(type="email", id="email", name="email", placeholder="yourname@sfsu.edu", required)
      button.btn-primary(type="submit") Reset Password
    
    p(style="text-align: center; margin-top: 1rem;")
      a(href="/login", style="color: #3b82f6; text-decoration: none;") ← Back to Login
