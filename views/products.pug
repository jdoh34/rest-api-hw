extends layout

block title
  | Products

block content
  h1 Our Homework Services
  
  .products-grid
    each product in products
      .product-card
        h3= product.name
        p Category: #{product.category}
        p Type: #{product.type}
        p University: #{product.university}
        p Price: $#{product.price}
        a(href=`/products/${product.name}`) View Details →