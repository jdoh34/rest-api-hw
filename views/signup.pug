extends layout

block content
  h1 ✨ Student Sign Up ✨
  p Get 15% OFF your first homework help session!
  
  .signup-form
    form(action="/signup", method="POST")
      input(type="text", name="name", placeholder="Full Name", required)
      input(type="email", name="email", placeholder="SFSU Email", required)
      select(name="year")
        option Freshman
        option Sophomore
        option Junior
        option Senior
      input(type="password", name="password", placeholder="Create Password", required)
      button(type="submit") 🎓 Get 15% Off →


  p.already Already have an account? 
    a(href="/login") Login here
